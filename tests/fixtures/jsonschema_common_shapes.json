{
  "raw_schemas": [
    {
      "type": [
        "string",
        "null"
      ]
    },
    {
      "$defs": {
        "CommonNodeResult": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "child": {
              "anyOf": [
                {
                  "$ref": "#/$defs/CommonNodeResult"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "name"
          ]
        }
      },
      "$ref": "#/$defs/CommonNodeResult"
    },
    {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ]
        },
        "tags": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "metadata": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": {
                "type": "number"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "value",
        "count"
      ]
    }
  ],
  "common_complex_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "CommonComplexResult",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "minLength": 3,
        "maxLength": 40,
        "pattern": "^[a-z][a-z0-9-]*$",
        "title": "Id"
      },
      "mode": {
        "default": "standard",
        "type": "string",
        "const": "standard",
        "title": "Mode"
      },
      "category": {
        "default": "alpha",
        "type": "string",
        "enum": [
          "alpha",
          "beta"
        ],
        "title": "Category"
      },
      "status": {
        "anyOf": [
          {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "done"
            ]
          },
          {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          }
        ],
        "title": "Status"
      },
      "score": {
        "default": 0,
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "multipleOf": 5,
        "title": "Score"
      },
      "confidence": {
        "default": 0.5,
        "type": "number",
        "exclusiveMinimum": 0,
        "exclusiveMaximum": 1,
        "multipleOf": 0.25,
        "title": "Confidence"
      },
      "owner": {
        "default": null,
        "title": "Owner",
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "title": "Name"
              },
              "tier": {
                "default": 1,
                "type": "integer",
                "minimum": 1,
                "maximum": 5,
                "title": "Tier"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          },
          {
            "type": "null"
          }
        ]
      },
      "tags": {
        "default": [],
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 24
        },
        "minItems": 0,
        "maxItems": 4,
        "title": "Tags"
      },
      "metrics": {
        "default": {},
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {
          "type": "object",
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991,
              "title": "Count"
            },
            "note": {
              "default": null,
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 20
                },
                {
                  "type": "null"
                }
              ],
              "title": "Note"
            },
            "samples": {
              "default": [
                0.25
              ],
              "type": "array",
              "items": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "multipleOf": 0.25
              },
              "minItems": 1,
              "maxItems": 3,
              "title": "Samples"
            }
          },
          "required": [
            "count"
          ],
          "additionalProperties": false,
          "title": "CommonMetric"
        },
        "title": "Metrics"
      },
      "regions": {
        "default": [],
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "kind": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "header",
                    "body",
                    "footer"
                  ]
                },
                {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                }
              ],
              "title": "Kind"
            },
            "visible": {
              "default": true,
              "type": "boolean",
              "title": "Visible"
            },
            "window": {
              "default": [
                0,
                10
              ],
              "type": "array",
              "prefixItems": [
                {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                }
              ],
              "minItems": 2,
              "maxItems": 2,
              "title": "Window"
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false,
          "title": "CommonRegion"
        },
        "title": "Regions"
      }
    },
    "required": [
      "id",
      "metrics",
      "regions",
      "status"
    ]
  },
